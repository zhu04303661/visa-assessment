# =====================================================
# GTV 签证评估系统 .gitignore
# =====================================================

# === 依赖 ===
/node_modules/

# === Next.js 构建产物 ===
/.next/
/out/
/build/

# === 调试日志 ===
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log
nohup.out

# === 环境变量 ===
.env*
!.env.example

# === Vercel ===
.vercel/

# === Python ===
*.pyc
__pycache__/
.venv/
venv/
*.egg-info/
ace_gtv/.venv_new/

# === TypeScript ===
*.tsbuildinfo
next-env.d.ts

# === PID 文件 ===
*.pid

# === 数据库 ===
*.db
*.db-journal
*.db.bak*

# === 日志目录 ===
/logs/
ace_gtv/logs/

# === 运行时数据目录 ===
/public/downloads/*
!/public/downloads/.gitkeep
/uploads/
/resumes/
/reports/
/personal_kb/
/minio-data/
ace_gtv/data/
ace_gtv/resumes/
ace_gtv/personal_kb/
ace_gtv/uploads/
ace_gtv/copywriting_projects/
ace_gtv/success_cases/
ace_gtv/assessments/

# === 二进制/大文件 ===
mc
minio
payload.so
*.so

# === Docker ===
.dockerignore

# === 备份目录 ===
bak/

# === 项目工作区（用户申请材料）===
project_workspaces/

# === Playwright ===
.playwright-mcp/

# === 办公文档（客户文件）===
*.xlsx
*.xls
*.xmind
*.docx
*.doc
*.pdf
*.ppt
*.pptx

# === 测试文件 ===
test-*.html
test-*.js

# === 杂项 ===
*.txt
!requirements.txt

# === IDE ===
.cursor/worktrees.json

# === JSON（保留必要配置）===
*.json
!package.json
!tsconfig.json
!components.json
!public/*.json
!deploy/**/*.json
!ecosystem.config.js
